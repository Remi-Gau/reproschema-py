{
    "@context": "https://raw.githubusercontent.com/ReproNim/reproschema/1.0.0-rc4/contexts/generic",
    "@type": "reproschema:Activity",
    "@id": "activity2_schema.jsonld",
    "prefLabel": "testing pref",
    "altLabel": "test alt label",
    "description": "trial",
    "schemaVersion": "1.0.0-rc4",
    "version": "0.0.1",
    "preamble": {
        "en": "this is test preamble"
    },
    "citation": "https://www.ncbi.nlm.nih.gov/pmc/articles/PMC1495268/",
    "image": {
        "@type": "AudioObject",
        "contentUrl": "http://example.com/sample-image.png"
    },
    "ui": {
        "order": [
            "./item_1",
            "./item_2",
            "./activity1_total_score"
        ],
        "addProperties": [
            {
                "variableName": "item_1",
                "isAbout": "./item_1",
                "isVis": true,
                "requiredValue": true,
                "allow": [
                    "reproschema:Skipped"
                ]
            },
            {
                "variableName": "item_2",
                "isAbout": "./item_2",
                "isVis": true,
                "requiredValue": true
            },
            {
                "variableName": "activity1_total_score",
                "isAbout": "./activity1_total_score",
                "isVis": false,
                "requiredValue": true,
                "allow": [
                    "reproschema:Skipped"
                ]
            }
        ],
        "shuffle": false,
        "allow": [
            "reproschema:Skipped"
        ]
    },

    "compute": {
        "variableName": "activity1_total_score",
        "jsExpression": "item1 + item2"
    }
}
